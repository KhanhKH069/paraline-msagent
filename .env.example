# ============================================================
# Paraline MSAgent — Environment Configuration
# Copy: cp .env.example .env  then chỉnh sửa theo hệ thống VMG
# ============================================================

# --- Network (VMG_STAFF LAN) ---
VMG_SERVER_IP=192.168.1.100

# --- Security (THAY ĐỔI TRƯỚC KHI DEPLOY!) ---
ADMIN_API_TOKEN=CHANGE_ME_RANDOM_32_CHARS_MINIMUM_LENGTH
CLIENT_API_KEY=CHANGE_ME_CLIENT_SECRET_KEY
DB_PASSWORD=paraline_strong_password

# --- Whisper STT ---
WHISPER_MODEL=large-v3
# Options: tiny | base | small | medium | large-v3
# large-v3: chất lượng tốt nhất cho JP, cần ~10GB GPU VRAM
# medium  : cân bằng tốt, cần ~5GB GPU VRAM
WHISPER_DEVICE=cuda        # cuda | cpu
WHISPER_COMPUTE_TYPE=float16   # float16 (GPU) | int8 (CPU)

# --- NLLB Translation ---
NLLB_MODEL=facebook/nllb-200-distilled-600M
# Options: nllb-200-distilled-600M (nhanh) | nllb-200-1.3B (cân bằng) | nllb-200-3.3B (tốt nhất)

# --- Piper TTS ---
PIPER_VOICE=vi_VN-vivos-medium
# Download voices: https://github.com/rhasspy/piper/releases
# vi_VN-vivos-low | vi_VN-vivos-medium | vi_VN-vivos-high

# --- Ollama LLM (Meeting Agent) ---
LLM_MODEL=llama3:8b
# Options: llama3:8b | gemma3:9b | qwen2.5:7b
# Sau khi `make up`, chạy: make pull-llm

# --- Vision (OCR + Inpainting) ---
OCR_LANG=japan+en
# japan: PaddleOCR JP mode | en: English only | japan+en: cả hai
INPAINT_ENGINE=opencv
# opencv: nhanh, đủ dùng | lama: chất lượng cao hơn (cần thêm model)

# --- Microsoft Teams Integration ---
# Cách 1: Incoming Webhook (dễ setup, chỉ gửi được)
TEAMS_WEBHOOK_URL=
# Lấy từ: Teams channel → ... → Connectors → Incoming Webhook

# Cách 2: Microsoft Graph API (đầy đủ tính năng — khuyến dùng)
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
# Hướng dẫn: docs/teams-graph-api-setup.md

# --- Auto-Join Meeting (Graph API) ---
# Channel dành riêng cho cuộc họp (chỉ 1 channel, agent sẽ luôn monitor)
# Lấy TEAMS_TEAM_ID:    GET https://graph.microsoft.com/v1.0/me/joinedTeams
# Lấy TEAMS_CHANNEL_ID: GET https://graph.microsoft.com/v1.0/teams/{team_id}/channels
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=
TEAMS_POLL_INTERVAL=10   # giây giữa 2 lần check meeting mới
# Permission cần thêm trong Azure AD App Registration:
#   OnlineMeetings.Read (Application permission)
#   ChannelMessage.Read.All (Application permission)

# --- Google Meet Integration (Chrome Extension) ---
# Python bridge lắng nghe events từ extension + queue để bơm chat vào Meet
MEET_BRIDGE_PORT=9877
# Giới hạn queue (tránh RAM tăng nếu spam)
MEET_CHAT_QUEUE_MAX=200


# --- Audio ---
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_MS=500         # Gửi chunk 500ms lên server → latency ~500ms
VIRTUAL_SPEAKER_NAME=CABLE Output   # Tên VB-Audio device
# Download VB-Audio: https://vb-audio.com/Cable/

# --- Logging ---
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
